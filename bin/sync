#!/usr/bin/env bash

# Sync Ralph, Skinner, PM skill, and prompt files into an existing project.
#
# Usage:
#   cornerstone/bin/sync /path/to/project          # sync all
#   cornerstone/bin/sync /path/to/project --only pm          # just PM scripts
#   cornerstone/bin/sync /path/to/project --only harnesses   # ralph + skinner
#   cornerstone/bin/sync /path/to/project --only prompts     # PROMPT.md + REVIEW.md
#   cornerstone/bin/sync /path/to/project --dry-run          # show what would change

set -euo pipefail

CORNERSTONE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
FILES_DIR="$CORNERSTONE_DIR/files"

DRY_RUN=false
ONLY=""
TARGET=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) DRY_RUN=true; shift ;;
    --only)    ONLY="$2"; shift 2 ;;
    -*)        echo "Unknown flag: $1"; exit 1 ;;
    *)         TARGET="$1"; shift ;;
  esac
done

if [[ -z "$TARGET" ]]; then
  echo "Usage: $(basename "$0") <target-project-dir> [--only pm|harnesses|prompts] [--dry-run]"
  exit 1
fi

TARGET="$(cd "$TARGET" && pwd)"

if [[ ! -d "$TARGET/.git" ]]; then
  echo "Error: $TARGET is not a git repository"
  exit 1
fi

if [[ -n "$ONLY" ]] && [[ "$ONLY" != "pm" && "$ONLY" != "harnesses" && "$ONLY" != "prompts" ]]; then
  echo "Error: --only must be pm, harnesses, or prompts"
  exit 1
fi

# --- helpers ---

# Files that are meant to be customized per-project.
# Sync warns instead of overwriting if they've been modified.
is_project_file() {
  case "$1" in
    PROMPT.md|REVIEW.md) return 0 ;;
    *) return 1 ;;
  esac
}

# Copy a file, respecting dry-run and project-file semantics.
# Usage: sync_file <source> <dest-relative-to-target> [--exec]
sync_file() {
  local src="$1"
  local rel="$2"
  local dest="$TARGET/$rel"
  local make_exec="${3:-}"

  if [[ -f "$dest" ]]; then
    if diff -q "$src" "$dest" > /dev/null 2>&1; then
      echo "  unchanged  $rel"
      return
    fi

    if is_project_file "$rel"; then
      echo "  SKIPPED  $rel (local changes — use --only prompts to overwrite)"
      return
    fi

    echo "  updated  $rel"
  else
    echo "  added    $rel"
  fi

  if [[ "$DRY_RUN" == true ]]; then
    if [[ -f "$dest" ]]; then
      diff -u "$dest" "$src" --label "current/$rel" --label "cornerstone/$rel" || true
    fi
    return
  fi

  mkdir -p "$(dirname "$dest")"
  cp "$src" "$dest"
  if [[ "$make_exec" == "--exec" ]]; then chmod +x "$dest"; fi
}

# --- sync groups ---

sync_pm() {
  for f in "$FILES_DIR/.claude/skills/project-management/"*; do
    local name
    name=$(basename "$f")
    if [[ "$name" == "SKILL.md" ]]; then
      sync_file "$f" ".claude/skills/project-management/$name"
    else
      sync_file "$f" ".claude/skills/project-management/$name" --exec
    fi
  done
}

sync_harnesses() {
  sync_file "$FILES_DIR/ralph" "ralph" --exec
  sync_file "$FILES_DIR/skinner" "skinner" --exec
}

sync_prompts() {
  # When explicitly requested via --only prompts, overwrite even project files.
  if [[ "$ONLY" == "prompts" ]]; then
    is_project_file() { return 1; }
  fi
  sync_file "$FILES_DIR/PROMPT.md" "PROMPT.md"
  sync_file "$FILES_DIR/REVIEW.md" "REVIEW.md"
}

ensure_permissions() {
  [[ "$DRY_RUN" == true ]] && return

  local settings="$TARGET/.claude/settings.local.json"
  mkdir -p "$TARGET/.claude"

  if [[ ! -f "$settings" ]]; then
    echo '{}' > "$settings"
  fi

  local result
  result=$(python3 - "$settings" <<'PYEOF'
import json, sys

path = sys.argv[1]
with open(path) as f:
    data = json.load(f)

allow = [
    "Bash(git status:*)",
    "Bash(git diff:*)",
    "Bash(git log:*)",
    "Bash(git show:*)",
    "Bash(git add:*)",
    "Bash(git commit:*)",
    "Bash(git rev-parse:*)",
    "Bash(gh issue:*)",
    "Bash(gh api:*)",
    "Bash(.claude/skills/project-management/*)",
    "Bash(bin/ci:*)",
    "Bash(bin/rails test:*)",
    "Bash(bin/setup:*)",
    "Bash(bin/dev:*)",
    "Bash(bin/rubocop:*)",
    "Bash(bin/brakeman:*)",
    "Bash(bundle:*)",
]

deny = [
    "Bash(rm -rf:*)",
]

perms = data.setdefault("permissions", {})
existing_allow = set(perms.get("allow", []))
existing_deny = set(perms.get("deny", []))

added_allow = [r for r in allow if r not in existing_allow]
added_deny = [r for r in deny if r not in existing_deny]

if not added_allow and not added_deny:
    print("unchanged")
    sys.exit(0)

perms["allow"] = sorted(existing_allow | set(allow))
perms["deny"] = sorted(existing_deny | set(deny))

with open(path, "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")

parts = []
if added_allow:
    parts.append(f"{len(added_allow)} allow")
if added_deny:
    parts.append(f"{len(added_deny)} deny")
print(", ".join(parts))
PYEOF
  ) || true

  if [[ "$result" == "unchanged" ]]; then
    echo "  unchanged  .claude/settings.local.json"
  else
    echo "  updated  .claude/settings.local.json (added $result rules)"
  fi
}

ensure_gitignore() {
  [[ "$DRY_RUN" == true ]] && return

  local changed=false
  for entry in .ralph/ .skinner/; do
    if ! grep -qxF "$entry" "$TARGET/.gitignore" 2>/dev/null; then
      echo "$entry" >> "$TARGET/.gitignore"
      changed=true
    fi
  done

  if [[ "$changed" == true ]]; then
    echo "  updated  .gitignore (added .ralph/, .skinner/)"
  fi
}

# --- main ---

$DRY_RUN && echo "DRY RUN — no files will be changed"
echo "Syncing cornerstone into: $TARGET"
echo ""

case "$ONLY" in
  pm)         sync_pm ;;
  harnesses)  sync_harnesses ;;
  prompts)    sync_prompts ;;
  *)          sync_pm; sync_harnesses; sync_prompts; ensure_permissions; ensure_gitignore ;;
esac

echo ""
if $DRY_RUN; then
  echo "Re-run without --dry-run to apply."
else
  echo "Done."
fi
