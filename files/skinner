#!/usr/bin/env bash

# Skinner — Async Review Harness for Ralph's implementations
#
# Reviews closed issues against their original specs, files issues
# for problems found, and updates CLAUDE.md with systemic learnings.
#
# Usage:
#   ./skinner              # continuous until all reviewed
#   ./skinner 10           # review 10 issues then stop

set -euo pipefail

LOG_DIR=".skinner"
PM=".claude/skills/project-management"
MAX_REVIEWS="${1:-0}"

source "$PM/config"

[[ "${1:-}" =~ ^[0-9]+$ ]] && MAX_REVIEWS="$1"

mkdir -p "$LOG_DIR"

echo "============================================================"
echo "  SKINNER"
echo "  repo:  $REPO"
echo "  max:   $( [[ $MAX_REVIEWS -eq 0 ]] && echo unlimited || echo $MAX_REVIEWS )"
echo "  logs:  $LOG_DIR/"
echo "============================================================"
echo ""

REVIEW=0
CONSECUTIVE_ISSUES=0
IDLE=0
MAX_IDLE_SLEEP=300  # 5 minutes

while true; do
  # Stay current with remote
  if ! git pull --rebase 2>/dev/null; then
    git rebase --abort 2>/dev/null || true
  fi

  # Poll for closed issues missing skinner:reviewed, excluding ralph:triage
  ISSUE=$(gh issue list --repo "$REPO" --state closed \
    --search "-label:skinner:reviewed -label:ralph:triage" \
    --json number --jq 'sort_by(.number) | .[0].number' 2>/dev/null || echo "")

  if [[ -z "$ISSUE" || "$ISSUE" == "null" ]]; then
    IDLE=$((IDLE + 1))
    SLEEP=$(( 2 ** IDLE > MAX_IDLE_SLEEP ? MAX_IDLE_SLEEP : 2 ** IDLE ))
    echo "--- $(date '+%H:%M:%S') | no issues to review, checking again in ${SLEEP}s ---"
    sleep "$SLEEP"
    continue
  fi
  IDLE=0

  REVIEW=$((REVIEW + 1))
  LOG_FILE="$LOG_DIR/review-$(printf '%04d' $REVIEW).log"

  echo "--- Review $REVIEW | $(date '+%H:%M:%S') | #$ISSUE | consecutive issues filed: $CONSECUTIVE_ISSUES/5 ---"

  # Build the review prompt
  PROMPT="$(sed "s/__NUMBER__/$ISSUE/g" REVIEW.md)"

  # Run claude
  PROMPT_FILE=$(mktemp)
  echo "$PROMPT" > "$PROMPT_FILE"
  script -q "$LOG_FILE" bash -c "claude --print -p - < \"$PROMPT_FILE\"" || true
  rm -f "$PROMPT_FILE"

  # If CLAUDE.md was modified, commit and push it
  if ! git diff --quiet CLAUDE.md 2>/dev/null; then
    echo "  Committing CLAUDE.md learnings"
    git add CLAUDE.md
    git commit -m "skinner: update learnings from review of #$ISSUE"
    if ! git pull --rebase 2>/dev/null; then
      git rebase --abort 2>/dev/null || true
    fi
    git push 2>/dev/null || true
  fi

  # Check if skinner filed any issues by scanning the log
  if grep -q "Created #" "$LOG_FILE" 2>/dev/null; then
    CONSECUTIVE_ISSUES=$((CONSECUTIVE_ISSUES + 1))
    echo "  Issues filed. Consecutive: $CONSECUTIVE_ISSUES/5"
  else
    CONSECUTIVE_ISSUES=0
  fi

  # Stall detection: 5 consecutive reviews that filed issues
  if [[ $CONSECUTIVE_ISSUES -ge 5 ]]; then
    echo "  5 consecutive reviews filed issues. Something is systemically wrong."
    echo "  Stopping for human review."
    break
  fi

  echo "  Log: $LOG_FILE"
  echo ""

  if [[ $MAX_REVIEWS -gt 0 ]] && [[ $REVIEW -ge $MAX_REVIEWS ]]; then
    echo "Reached $MAX_REVIEWS reviews. Stopping."
    break
  fi

  sleep 2
done

echo ""
echo "Skinner out. Reviewed $REVIEW issues."
