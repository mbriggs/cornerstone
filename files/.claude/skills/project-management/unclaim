#!/usr/bin/env bash
# Releases a claimed issue by removing the "ralph:wip" label.
# Usage: unclaim <issue-number>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/config"
NUM="${1:?Usage: unclaim <issue-number>}"

gh issue edit "$NUM" --repo "$REPO" --remove-label "ralph:wip"
echo "Unclaimed #$NUM"
