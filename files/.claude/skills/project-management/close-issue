#!/usr/bin/env bash
# Closes an issue with a commit reference comment and removes ralph:wip label.
# If the issue's milestone has no remaining open issues, closes the milestone too.
# Usage: close-issue <issue-number>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/config"
NUM="${1:?Usage: close-issue <issue-number>}"
SHA=$(git rev-parse --short HEAD)

gh issue close "$NUM" --repo "$REPO" --comment "Implemented in $SHA."
gh issue edit "$NUM" --repo "$REPO" --remove-label "ralph:wip" --add-label "ralph:done" 2>/dev/null || true
echo "Closed #$NUM ($SHA)"

# Close milestone if it's now empty
MS_TITLE=$(gh issue view "$NUM" --repo "$REPO" --json milestone --jq '.milestone.title // empty' 2>/dev/null || echo "")
if [[ -n "$MS_TITLE" ]]; then
  REMAINING=$(gh issue list --repo "$REPO" --state open --milestone "$MS_TITLE" --json number --jq length 2>/dev/null || echo "")
  if [[ "$REMAINING" == "0" ]]; then
    "$SCRIPT_DIR/close-milestone" "$MS_TITLE" 2>/dev/null || true
  fi
fi
