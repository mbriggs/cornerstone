#!/usr/bin/env bash
# Prints the next milestone that has open issues.
# Usage: next-milestone

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/config"

NEXT=$(gh api "repos/$REPO/milestones" --jq '
  sort_by(.title) | .[] | select(.open_issues > 0) | .title' | head -1)

if [[ -z "$NEXT" ]]; then
  echo "All milestones complete!" >&2
  exit 1
fi

echo "$NEXT"
