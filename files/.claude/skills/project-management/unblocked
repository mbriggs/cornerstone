#!/usr/bin/env bash
# Lists all open, unblocked, unclaimed issues ralph can work on.
# Milestone issues first (sorted by milestone, then number), then backlog.
# Usage: unblocked

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/config"

SEARCH="-is:blocked -label:ralph:wip -label:human:claimed"

# Milestone issues first
MILESTONE=$("$SCRIPT_DIR/milestone" 2>/dev/null || echo "")
if [[ -n "$MILESTONE" ]]; then
  gh issue list --repo "$REPO" --state open --milestone "$MILESTONE" \
    --search "$SEARCH" --json number,title \
    --jq 'sort_by(.number)[] | "#\(.number) \(.title)"'
fi

# Then backlog (no milestone)
gh issue list --repo "$REPO" --state open \
  --search "no:milestone $SEARCH" --json number,title \
  --jq 'sort_by(.number)[] | "#\(.number) \(.title)"'
