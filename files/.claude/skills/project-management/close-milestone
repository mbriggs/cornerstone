#!/usr/bin/env bash
# Closes a milestone.
# Usage: close-milestone "M1: Foundation"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/config"
TITLE="${1:?Usage: close-milestone \"milestone title\"}"

NUMBER=$(gh api "repos/$REPO/milestones" --jq ".[] | select(.title == \"$TITLE\") | .number")

if [[ -z "$NUMBER" ]]; then
  echo "Milestone not found: $TITLE"
  exit 1
fi

gh api "repos/$REPO/milestones/$NUMBER" -X PATCH -f state=closed --jq '.title' >/dev/null
echo "Closed milestone: $TITLE"
