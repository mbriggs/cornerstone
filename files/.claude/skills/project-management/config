#!/usr/bin/env bash
# Shared config for project-management scripts.
# Derives repo info from git remote origin.
# Sourced by all scripts — not executed directly.

REPO=$(git remote get-url origin 2>/dev/null | sed 's|.*github.com[:/]||; s|\.git$||') || true
if [[ -z "$REPO" ]]; then
  echo "Could not determine GitHub repo from git remote" >&2
  exit 1
fi

REPO_OWNER="${REPO%%/*}"
REPO_NAME="${REPO##*/}"
