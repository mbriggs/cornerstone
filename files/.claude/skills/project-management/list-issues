#!/usr/bin/env bash
# Lists issues in a milestone.
# Usage: list-issues "M1: Foundation" [--closed]
#
# By default shows open issues. Pass --closed to show closed instead.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/config"

MILESTONE=""
STATE="open"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --closed) STATE="closed"; shift ;;
    *)
      if [[ -z "$MILESTONE" ]]; then
        MILESTONE="$1"; shift
      else
        echo "Unknown argument: $1" >&2; exit 1
      fi
      ;;
  esac
done

if [[ -z "$MILESTONE" ]]; then
  echo "Usage: list-issues \"milestone title\" [--closed]" >&2
  exit 1
fi

gh issue list --repo "$REPO" --state "$STATE" --milestone "$MILESTONE" \
  --json number,title --jq 'sort_by(.number)[] | "#\(.number) \(.title)"'
