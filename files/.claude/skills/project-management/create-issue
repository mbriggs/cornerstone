#!/usr/bin/env bash
# Creates a GitHub issue with optional milestone and blocked-by relationship.
# Usage: create-issue "title" --body "markdown" [--milestone "M1: ..."] [--blocked-by 42]
#
# The --blocked-by flag adds an issue dependency via GitHub's addBlockedBy API,
# which makes the issue show up in is:blocked search filters.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/config"

TITLE=""
BODY=""
MILESTONE=""
BLOCKED_BY=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --body)       BODY="$2";       shift 2 ;;
    --milestone)  MILESTONE="$2";  shift 2 ;;
    --blocked-by) BLOCKED_BY="$2"; shift 2 ;;
    *)
      if [[ -z "$TITLE" ]]; then
        TITLE="$1"; shift
      else
        echo "Unknown argument: $1" >&2; exit 1
      fi
      ;;
  esac
done

if [[ -z "$TITLE" ]]; then
  echo "Usage: create-issue \"title\" --body \"markdown\" [--milestone \"M1: ...\"] [--blocked-by 42]" >&2
  exit 1
fi

# Build REST API args
API_ARGS=(-f "title=$TITLE")
[[ -n "$BODY" ]] && API_ARGS+=(-f "body=$BODY")

# Resolve milestone name -> number
if [[ -n "$MILESTONE" ]]; then
  MS_NUM=$(gh api "repos/$REPO/milestones" \
    --jq ".[] | select(.title == \"$MILESTONE\") | .number")
  if [[ -z "$MS_NUM" ]]; then
    echo "Milestone not found: $MILESTONE" >&2; exit 1
  fi
  API_ARGS+=(-F "milestone=$MS_NUM")
fi

# Create the issue via REST API
NUM=$(gh api "repos/$REPO/issues" "${API_ARGS[@]}" --jq '.number')

echo "Created #$NUM: $TITLE"

# If --blocked-by is set, add a dependency so this issue is blocked by the parent
if [[ -n "$BLOCKED_BY" ]]; then
  BLOCKER_ID=$(gh api graphql \
    -f query="query { repository(owner:\"$REPO_OWNER\", name:\"$REPO_NAME\") { issue(number:$BLOCKED_BY) { id } } }" \
    --jq '.data.repository.issue.id')

  ISSUE_ID=$(gh api graphql \
    -f query="query { repository(owner:\"$REPO_OWNER\", name:\"$REPO_NAME\") { issue(number:$NUM) { id } } }" \
    --jq '.data.repository.issue.id')

  gh api graphql \
    -f query="mutation { addBlockedBy(input: { issueId: \"$ISSUE_ID\", blockingIssueId: \"$BLOCKER_ID\" }) { clientMutationId } }" \
    --silent

  echo "  -> blocked by #$BLOCKED_BY"
fi
