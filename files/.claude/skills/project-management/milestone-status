#!/usr/bin/env bash
# Shows status for a milestone: open/closed counts, blocked/unblocked/wip breakdown.
# Usage: milestone-status "M1: Foundation"
#        milestone-status              (uses next open milestone)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/config"

MILESTONE="${1:-$("$SCRIPT_DIR/next-milestone")}"

# Fetch milestone metadata
MS_JSON=$(gh api "repos/$REPO/milestones" \
  --jq ".[] | select(.title == \"$MILESTONE\")")

if [[ -z "$MS_JSON" ]]; then
  echo "Milestone not found: $MILESTONE" >&2; exit 1
fi

OPEN=$(echo "$MS_JSON" | jq '.open_issues')
CLOSED=$(echo "$MS_JSON" | jq '.closed_issues')
TOTAL=$((OPEN + CLOSED))

echo "$MILESTONE  ($CLOSED/$TOTAL done)"
echo ""

# Fetch open issues in this milestone
if [[ "$OPEN" -eq 0 ]]; then
  echo "All issues closed!"
  exit 0
fi

# WIP (claimed) issues
WIP=$(gh issue list --repo "$REPO" --state open --milestone "$MILESTONE" \
  --label "ralph:wip" --json number,title \
  --jq 'sort_by(.number)[] | "#\(.number) \(.title)"' 2>/dev/null || true)

# Blocked issues (not wip)
BLOCKED=$(gh issue list --repo "$REPO" --state open --milestone "$MILESTONE" \
  --search "is:blocked -label:ralph:wip" --json number,title \
  --jq 'sort_by(.number)[] | "#\(.number) \(.title)"' 2>/dev/null || true)

# Unblocked and unclaimed
READY=$(gh issue list --repo "$REPO" --state open --milestone "$MILESTONE" \
  --search "-is:blocked -label:ralph:wip" --json number,title \
  --jq 'sort_by(.number)[] | "#\(.number) \(.title)"' 2>/dev/null || true)

if [[ -n "$WIP" ]]; then
  echo "In progress:"
  echo "$WIP" | sed 's/^/  /'
  echo ""
fi

if [[ -n "$READY" ]]; then
  echo "Ready:"
  echo "$READY" | sed 's/^/  /'
  echo ""
fi

if [[ -n "$BLOCKED" ]]; then
  echo "Blocked:"
  echo "$BLOCKED" | sed 's/^/  /'
  echo ""
fi
