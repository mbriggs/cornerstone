#!/usr/bin/env bash
# Creates a new milestone.
# Usage: add-milestone "M1: Foundation"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/config"
TITLE="${1:?Usage: add-milestone \"milestone title\"}"

gh api "repos/$REPO/milestones" -f title="$TITLE" --jq '.title' >/dev/null 2>&1
echo "Created milestone: $TITLE"
