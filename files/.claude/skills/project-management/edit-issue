#!/usr/bin/env bash
# Updates an issue's title and/or body.
# Usage: edit-issue <issue-number> [--title "new title"] [--body "new body"]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/config"

ISSUE=""
TITLE=""
BODY=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --title) TITLE="$2"; shift 2 ;;
    --body)  BODY="$2";  shift 2 ;;
    *)
      if [[ -z "$ISSUE" ]]; then
        ISSUE="$1"; shift
      else
        echo "Unknown argument: $1" >&2; exit 1
      fi
      ;;
  esac
done

if [[ -z "$ISSUE" ]]; then
  echo "Usage: edit-issue <issue-number> [--title \"new title\"] [--body \"new body\"]" >&2
  exit 1
fi

if [[ -z "$TITLE" && -z "$BODY" ]]; then
  echo "Nothing to update — pass --title and/or --body" >&2
  exit 1
fi

ARGS=()
[[ -n "$TITLE" ]] && ARGS+=(--title "$TITLE")
[[ -n "$BODY" ]]  && ARGS+=(--body "$BODY")

gh issue edit "$ISSUE" --repo "$REPO" "${ARGS[@]}"
echo "Updated #$ISSUE"
