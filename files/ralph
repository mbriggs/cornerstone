#!/usr/bin/env bash

# Ralph Wiggum build harness for Claude Code
#
# Usage:
#   ./ralph              # continuous until all work done
#   ./ralph 10           # run 10 loops then stop

set -euo pipefail

LOG_DIR=".ralph"
PM=".claude/skills/project-management"
MAX_LOOPS="${1:-0}"

source "$PM/config"

[[ "${1:-}" =~ ^[0-9]+$ ]] && MAX_LOOPS="$1"

mkdir -p "$LOG_DIR"

echo "============================================================"
echo "  RALPH WIGGUM"
echo "  repo:  $REPO"
echo "  max:   $( [[ $MAX_LOOPS -eq 0 ]] && echo unlimited || echo $MAX_LOOPS )"
echo "  logs:  $LOG_DIR/"
echo "============================================================"
echo ""

LOOP=0
STALLS=0
IDLE=0
MAX_IDLE_SLEEP=300  # 5 minutes

while true; do
  LOOP=$((LOOP + 1))
  LOG_FILE="$LOG_DIR/loop-$(printf '%04d' $LOOP).log"
  SHA_BEFORE=$(git rev-parse --short HEAD 2>/dev/null || echo "none")

  # Check for available work
  MILESTONE=$("$PM/milestone" 2>/dev/null || echo "")
  AVAILABLE=$("$PM/unblocked" 2>/dev/null | head -5)

  if [[ -z "$AVAILABLE" ]]; then
    IDLE=$((IDLE + 1))
    SLEEP=$(( 2 ** IDLE > MAX_IDLE_SLEEP ? MAX_IDLE_SLEEP : 2 ** IDLE ))
    echo "--- Loop $LOOP | $(date '+%H:%M:%S') | no work available, checking again in ${SLEEP}s ---"
    sleep "$SLEEP"
    continue
  fi
  IDLE=0

  LABEL="${MILESTONE:-backlog}"
  COUNT=$(echo "$AVAILABLE" | wc -l | tr -d ' ')
  echo "--- Loop $LOOP | $(date '+%H:%M:%S') | $LABEL | available: $COUNT | stalls: $STALLS/3 ---"

  # Unclaim stale ralph:wip issues from previous interrupted runs
  STALE_WIP=$(gh issue list --repo "$REPO" --state open --label "ralph:wip" --json number --jq '.[].number' 2>/dev/null || echo "")
  for NUM in $STALE_WIP; do
    "$PM/unclaim" "$NUM" 2>/dev/null || true
    echo "  Unclaimed stale #$NUM"
  done

  # Run claude in a PTY so output streams in real time
  script -q "$LOG_FILE" bash -c "claude --print -p - < PROMPT.md" || true

  # Safety net: commit staged changes Claude missed
  if ! git diff --cached --quiet 2>/dev/null; then
    echo "  Safety net: committing staged changes"
    git add app/ config/ db/ lib/ test/ bin/setup bin/ci CLAUDE.md Gemfile Gemfile.lock Rakefile .rubocop.yml .mise.toml Procfile.dev 2>/dev/null || true
    git commit -m "ralph: auto-commit from loop $LOOP" || true
  fi

  # Safety net: push unpushed commits
  BRANCH=$(git branch --show-current)
  LOCAL=$(git rev-parse HEAD 2>/dev/null || echo "none")
  REMOTE=$(git rev-parse "origin/$BRANCH" 2>/dev/null || echo "none")
  if [[ "$LOCAL" != "$REMOTE" ]]; then
    echo "  Safety net: pulling before push"
    if ! git pull --rebase 2>/dev/null; then
      echo "  Rebase conflict — attempting auto-resolve"
      CONFLICTED=$(git diff --name-only --diff-filter=U 2>/dev/null || echo "")
      if [[ -n "$CONFLICTED" ]]; then
        UNRESOLVABLE=false
        for f in $CONFLICTED; do
          case "$f" in
            # Non-code files: keep ours (ralph's version)
            .ruby-version|.claude/*|CLAUDE.md|PROMPT.md|ralph|skinner|.ralph/*|.skinner/*)
              git checkout --ours "$f" && git add "$f"
              echo "    resolved (ours): $f"
              ;;
            # Code files: attempt merge, use Claude for conflicts
            *)
              if grep -q '<<<<<<<' "$f" 2>/dev/null; then
                echo "    conflict in $f — asking Claude to resolve"
                OURS_MSG=$(git log --format=%s -1 HEAD 2>/dev/null || echo "unknown")
                THEIRS_MSG=$(git log --format=%s -1 REBASE_HEAD 2>/dev/null || echo "unknown")
                claude --print -p "Resolve the merge conflict in $f. The file has git conflict markers.

Ours (current branch): $OURS_MSG
Theirs (incoming): $THEIRS_MSG

Read the file, understand what both sides intended, pick the correct resolution that preserves all intended changes from both sides, then edit the file to remove all conflict markers. Do not add or remove functionality — just merge correctly." 2>/dev/null
                # Verify Claude actually resolved it
                if grep -q '<<<<<<<' "$f" 2>/dev/null; then
                  echo "    Claude failed to resolve: $f"
                  UNRESOLVABLE=true
                else
                  git add "$f"
                  echo "    resolved (claude): $f"
                fi
              else
                git add "$f"
                echo "    resolved (auto): $f"
              fi
              ;;
          esac
        done

        if $UNRESOLVABLE; then
          echo "  Code conflicts remain — aborting rebase and stopping."
          git rebase --abort 2>/dev/null || true
          break
        fi

        GIT_EDITOR=true git rebase --continue 2>/dev/null || {
          echo "  Rebase --continue failed — aborting."
          git rebase --abort 2>/dev/null || true
          break
        }
        echo "  Rebase resolved — running CI to verify merge"
        if ! bin/ci 2>/dev/null; then
          echo "  CI failed after conflict resolution — stopping for human review."
          break
        fi
        echo "  CI passed after merge"
      else
        git rebase --abort 2>/dev/null || true
        break
      fi
    fi
    echo "  Safety net: pushing"
    git push -u origin "$BRANCH" 2>/dev/null || true
  fi

  SHA_AFTER=$(git rev-parse --short HEAD 2>/dev/null || echo "none")

  if [[ "$SHA_BEFORE" != "$SHA_AFTER" ]]; then
    STALLS=0
    echo "  Committed: $SHA_AFTER"

    # Close any claimed issues now that code is pushed
    CLAIMED=$(gh issue list --repo "$REPO" --state open --label "ralph:wip" --json number --jq '.[].number' 2>/dev/null || echo "")
    for NUM in $CLAIMED; do
      "$PM/close-issue" "$NUM" 2>/dev/null || true
      echo "  Closed #$NUM"
    done
  else
    STALLS=$((STALLS + 1))
    echo "  No commits. Stall $STALLS/3."

    # Unclaim any ralph:wip issues so next loop can re-pick
    CLAIMED=$(gh issue list --repo "$REPO" --state open --label "ralph:wip" --json number --jq '.[].number' 2>/dev/null || echo "")
    for NUM in $CLAIMED; do
      "$PM/unclaim" "$NUM" 2>/dev/null || true
      echo "  Unclaimed #$NUM"
    done

    if [[ $STALLS -ge 3 ]]; then
      echo "  3 stalls. Ralph is stuck. Check logs."
      break
    fi
  fi

  echo "  Log: $LOG_FILE"
  echo ""

  if [[ $MAX_LOOPS -gt 0 ]] && [[ $LOOP -ge $MAX_LOOPS ]]; then
    echo "Reached $MAX_LOOPS loops. Stopping."
    break
  fi

  sleep 2
done

echo ""
echo "Ralph out. Ran $LOOP loops."
